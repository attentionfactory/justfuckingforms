# JFF environment variables.
# Copy to .env.local (gitignored) and fill in. Each app/package reads what it needs.

# ---- Database ---------------------------------------------------------------
# Neon Postgres HTTP connection string (https://neon.tech). Used by both
# apps/api (CF Workers, neon-http driver) and packages/db (drizzle-kit migrate).
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/jff?sslmode=require

# ---- Better Auth ------------------------------------------------------------
# 32+ char random secret. Used to sign session tokens.
BETTER_AUTH_SECRET=
# Public URL where the auth handler is mounted (e.g. https://justfuckingforms.com).
BETTER_AUTH_URL=http://localhost:3000

# ---- Resend (transactional email) -------------------------------------------
RESEND_API_KEY=

# ---- Polar (billing) --------------------------------------------------------
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# ---- Sentry (errors) --------------------------------------------------------
SENTRY_DSN=

# ---- Web app ---------------------------------------------------------------
# Base URL of the API. apps/web hits this for forms/submissions/inbox CRUD.
NEXT_PUBLIC_API_URL=http://localhost:8787
